---
import { getCollection } from "astro:content";
import {
  ArrowUpRight,
  BookOpen,
  FolderKanban,
  Github,
  Mail,
  Search,
  Sparkles,
} from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";
import { siteConfig } from "@/site.config";
import { formatDate, getReadingTime, sortPosts } from "@/utils/blog";

const posts = sortPosts(await getCollection("blog"));
const featuredPosts = posts.filter((post) => post.data.featured);
const recentPosts = posts.slice(0, 4);
const featuredProjects = projects.filter((project) => project.featured);

const searchItems = [
  ...posts.map((post) => ({
    type: "文章",
    title: post.data.title,
    description: post.data.description,
    href: `/blog/${post.slug}/`,
    tags: post.data.tags,
  })),
  ...projects.map((project) => ({
    type: "项目",
    title: project.title,
    description: project.description,
    href: project.href,
    tags: project.stack,
  })),
];
---

<BaseLayout>
  <section class="home-shell">
    <div class="hero-grid">
      <section class="search-panel panel" aria-labelledby="search-title">
        <p class="eyebrow">Start Page</p>
        <h1 id="search-title">{siteConfig.title}</h1>
        <p class="hero-copy">{siteConfig.description}</p>

        <form class="search-form" id="search-form">
          <label class="search-label" for="search-input">搜索</label>
          <div class="search-box">
            <Search size={22} aria-hidden="true" />
            <input
              id="search-input"
              name="q"
              type="search"
              autocomplete="off"
              placeholder="搜索网页、GitHub 或站内内容"
            />
            <button type="submit">Search</button>
          </div>
          <div class="engine-tabs" role="radiogroup" aria-label="搜索引擎">
            <button type="button" data-engine="google" aria-pressed="true">Google</button>
            <button type="button" data-engine="bing" aria-pressed="false">Bing</button>
            <button type="button" data-engine="github" aria-pressed="false">GitHub</button>
            <button type="button" data-engine="site" aria-pressed="false">Site</button>
          </div>
        </form>

        <div class="site-results" id="site-results" hidden>
          <div class="results-head">
            <strong>站内结果</strong>
            <span id="result-count" aria-live="polite"></span>
          </div>
          <div class="result-list" id="result-list"></div>
        </div>
      </section>

      <aside class="profile-panel panel" aria-labelledby="profile-title">
        <img
          src={siteConfig.avatar}
          width="96"
          height="96"
          alt={`${siteConfig.nickname} 的头像`}
          loading="eager"
        />
        <p class="eyebrow">About</p>
        <h2 id="profile-title">{siteConfig.nickname}</h2>
        <p class="tagline">{siteConfig.tagline}</p>
        <p>{siteConfig.description}</p>
        <div class="contact-row">
          <a href={siteConfig.github}>
            <Github size={18} aria-hidden="true" />
            GitHub
          </a>
          <a href={`mailto:${siteConfig.email}`}>
            <Mail size={18} aria-hidden="true" />
            Email
          </a>
        </div>
      </aside>
    </div>

    <section class="quick-section" aria-labelledby="quick-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Shortcuts</p>
          <h2 id="quick-title">项目快捷入口</h2>
        </div>
        <a class="text-link" href="/projects/">查看全部 <ArrowUpRight size={16} /></a>
      </div>
      <div class="project-grid">
        {
          featuredProjects.map((project) => (
            <a class="project-card card" href={project.href}>
              <div class="card-icon">
                <FolderKanban size={20} aria-hidden="true" />
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul class="tag-list" aria-label={`${project.title} 技术栈`}>
                {project.stack.map((item) => <li class="tag">{item}</li>)}
              </ul>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-grid" aria-label="文章">
      <div>
        <div class="section-heading">
          <div>
            <p class="eyebrow">Featured</p>
            <h2>精选文章</h2>
          </div>
          <a class="text-link" href="/blog/">博客列表 <ArrowUpRight size={16} /></a>
        </div>
        <div class="article-list featured-list">
          {
            featuredPosts.map((post) => (
              <a class="article-card card" href={`/blog/${post.slug}/`}>
                <div class="article-meta">
                  <span>{formatDate(post.data.pubDate)}</span>
                  <span>{getReadingTime(post.body)} min read</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <ul class="tag-list">
                  {post.data.tags.map((tag) => <li class="tag">{tag}</li>)}
                </ul>
              </a>
            ))
          }
        </div>
      </div>

      <aside class="recent-panel panel" aria-labelledby="recent-title">
        <div class="recent-head">
          <Sparkles size={18} aria-hidden="true" />
          <h2 id="recent-title">最近更新</h2>
        </div>
        <div class="recent-list">
          {
            recentPosts.map((post) => (
              <a href={`/blog/${post.slug}/`}>
                <BookOpen size={17} aria-hidden="true" />
                <span>
                  <strong>{post.data.title}</strong>
                  <small>{formatDate(post.data.pubDate)}</small>
                </span>
              </a>
            ))
          }
        </div>
      </aside>
    </section>
  </section>

<script is:inline define:vars={{ searchItems }}>
  const engines = {
    google: "https://www.google.com/search?q=",
    bing: "https://www.bing.com/search?q=",
    github: "https://github.com/search?q=",
  };

  const storageKey = "myblog.searchEngine";
  const form = document.querySelector("#search-form");
  const input = document.querySelector("#search-input");
  const buttons = Array.from(document.querySelectorAll("[data-engine]"));
  const resultsPanel = document.querySelector("#site-results");
  const resultList = document.querySelector("#result-list");
  const resultCount = document.querySelector("#result-count");
  let activeEngine = localStorage.getItem(storageKey) || "google";

  function setEngine(engine) {
    activeEngine = engine;
    localStorage.setItem(storageKey, engine);
    buttons.forEach((button) => {
      const selected = button.dataset.engine === engine;
      button.setAttribute("aria-pressed", String(selected));
    });
    if (engine !== "site") {
      resultsPanel.hidden = true;
    }
  }

  function renderSiteResults(query) {
    const normalized = query.trim().toLowerCase();
    if (!normalized) {
      resultsPanel.hidden = true;
      return;
    }

    const matches = searchItems
      .filter((item) => {
        const haystack = [item.type, item.title, item.description, ...(item.tags || [])]
          .join(" ")
          .toLowerCase();
        return haystack.includes(normalized);
      })
      .slice(0, 8);

    resultList.replaceChildren(
      ...matches.map((item) => {
        const link = document.createElement("a");
        link.className = "result-item";
        link.href = item.href;
        link.innerHTML = `
          <span>${item.type}</span>
          <strong>${item.title}</strong>
          <small>${item.description}</small>
        `;
        return link;
      }),
    );

    resultCount.textContent = matches.length ? `${matches.length} 个匹配` : "没有匹配";
    resultsPanel.hidden = false;
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      setEngine(button.dataset.engine);
      if (button.dataset.engine === "site") {
        renderSiteResults(input.value);
        input.focus();
      }
    });
  });

  input.addEventListener("input", () => {
    if (activeEngine === "site") {
      renderSiteResults(input.value);
    }
  });

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    const query = input.value.trim();
    if (!query) {
      input.focus();
      return;
    }

    if (activeEngine === "site") {
      renderSiteResults(query);
      return;
    }

    window.location.href = `${engines[activeEngine]}${encodeURIComponent(query)}`;
  });

  setEngine(engines[activeEngine] ? activeEngine : "google");
</script>
</BaseLayout>

<style>
  .home-shell {
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
    padding: 42px 0 80px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.8fr);
    gap: 16px;
    align-items: stretch;
  }

  .search-panel,
  .profile-panel,
  .recent-panel {
    padding: clamp(22px, 4vw, 36px);
  }

  .search-panel h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.5rem, 7vw, 5.7rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .hero-copy {
    max-width: 620px;
    margin: 20px 0 30px;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.14rem);
  }

  .search-form {
    max-width: 760px;
  }

  .search-label {
    display: block;
    margin-bottom: 10px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .search-box {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    min-height: 64px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: #0f0f12;
    padding: 8px 8px 8px 18px;
  }

  .search-box svg {
    color: var(--accent);
  }

  .search-box input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text);
    font-size: clamp(1rem, 2vw, 1.18rem);
  }

  .search-box input::placeholder {
    color: var(--subtle);
  }

  .search-box button,
  .engine-tabs button {
    min-height: 44px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    color: var(--text);
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .search-box button {
    background: var(--accent-strong);
    padding: 0 18px;
    font-weight: 700;
  }

  .search-box button:hover {
    background: #1d4ed8;
  }

  .engine-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .engine-tabs button {
    background: var(--surface-strong);
    padding: 0 14px;
  }

  .engine-tabs button[aria-pressed="true"] {
    border-color: rgba(96, 165, 250, 0.8);
    background: rgba(37, 99, 235, 0.22);
    color: #dbeafe;
  }

  .site-results {
    margin-top: 20px;
    border-top: 1px solid var(--border);
    padding-top: 18px;
  }

  .results-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
    color: var(--muted);
  }

  .result-list {
    display: grid;
    gap: 8px;
  }

  .result-item {
    display: grid;
    gap: 2px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 14px;
    background: var(--surface);
  }

  .result-item span {
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .result-item small {
    color: var(--muted);
  }

  .profile-panel img {
    width: 96px;
    height: 96px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    object-fit: cover;
  }

  .profile-panel h2 {
    margin: 12px 0 0;
    font-size: 1.8rem;
  }

  .profile-panel p {
    color: var(--muted);
  }

  .tagline {
    margin-top: 4px;
    color: var(--text) !important;
    font-weight: 700;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .contact-row a,
  .text-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0 12px;
    color: var(--muted);
    font-weight: 700;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .contact-row a:hover,
  .text-link:hover {
    border-color: var(--border-strong);
    background: var(--surface-strong);
    color: var(--text);
  }

  .quick-section,
  .content-grid {
    margin-top: 34px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .project-card,
  .article-card {
    display: grid;
    min-height: 220px;
    align-content: start;
    gap: 12px;
    padding: 22px;
  }

  .card-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--accent);
  }

  .project-card h3,
  .article-card h3 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.25;
  }

  .project-card p,
  .article-card p {
    margin: 0;
    color: var(--muted);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 16px;
  }

  .article-list {
    display: grid;
    gap: 16px;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    color: var(--subtle);
    font-size: 0.86rem;
  }

  .recent-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .recent-head h2 {
    margin: 0;
    font-size: 1.16rem;
  }

  .recent-head svg {
    color: var(--amber);
  }

  .recent-list {
    display: grid;
    gap: 10px;
  }

  .recent-list a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    align-items: start;
    border-radius: var(--radius);
    padding: 10px;
    color: var(--muted);
    transition:
      background 180ms ease,
      color 180ms ease;
  }

  .recent-list a:hover {
    background: var(--surface-strong);
    color: var(--text);
  }

  .recent-list strong,
  .recent-list small {
    display: block;
  }

  .recent-list small {
    margin-top: 2px;
    color: var(--subtle);
  }

  @media (max-width: 900px) {
    .hero-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .home-shell {
      width: min(100% - 24px, 1160px);
      padding-top: 24px;
    }

    .search-box {
      grid-template-columns: auto 1fr;
    }

    .search-box button {
      grid-column: 1 / -1;
      width: 100%;
    }
  }
</style>
