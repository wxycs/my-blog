---
import { ArrowUpRight, FolderKanban } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";
---

<BaseLayout title="Projects" description="快乐小屋的项目入口">
  <section class="page-shell">
    <div class="page-title">
      <p class="eyebrow">Projects</p>
      <h1>项目</h1>
      <p>先放占位项目，后续可以替换成真实作品、工具、仓库和长期维护的内容。</p>
    </div>

    <div class="project-list">
      {
        projects.map((project) => (
          <a class="project-card card" href={project.href}>
            <div class="project-top">
              <span class="card-icon">
                <FolderKanban size={20} aria-hidden="true" />
              </span>
              <ArrowUpRight size={18} aria-hidden="true" />
            </div>
            <h2>{project.title}</h2>
            <p>{project.description}</p>
            <ul class="tag-list">
              {project.stack.map((item) => <li class="tag">{item}</li>)}
            </ul>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    max-width: 720px;
    margin-bottom: 28px;
  }

  .page-title h1 {
    margin: 0;
    font-size: clamp(2.3rem, 6vw, 4.8rem);
    line-height: 1;
  }

  .page-title p:last-child {
    color: var(--muted);
    font-size: 1.08rem;
  }

  .project-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .project-card {
    display: grid;
    min-height: 250px;
    align-content: start;
    gap: 14px;
    padding: 24px;
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
  }

  .card-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--accent);
  }

  .project-card h2,
  .project-card p {
    margin: 0;
  }

  .project-card h2 {
    font-size: 1.35rem;
  }

  .project-card p {
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .project-list {
      grid-template-columns: 1fr;
    }
  }
</style>
