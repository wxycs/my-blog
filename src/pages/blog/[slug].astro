---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate, getReadingTime } from "@/utils/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <a class="back-link" href="/blog/">Blog</a>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="article-meta">
        <span>{formatDate(post.data.pubDate)}</span>
        <span>{getReadingTime(post.body)} min read</span>
      </div>
      <ul class="tag-list">
        {post.data.tags.map((tag) => <li class="tag">{tag}</li>)}
      </ul>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    width: min(780px, calc(100% - 32px));
    margin: 0 auto;
    padding: 54px 0 90px;
  }

  .article-header {
    margin-bottom: 36px;
  }

  .back-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0 12px;
    color: var(--muted);
    font-weight: 700;
  }

  .article-header h1 {
    margin: 24px 0 16px;
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 1.05;
  }

  .article-header p {
    margin: 0;
    color: var(--muted);
    font-size: 1.12rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 20px 0 16px;
    color: var(--subtle);
    font-size: 0.9rem;
  }

  .prose {
    color: #e4e4e7;
    font-size: 1.05rem;
    line-height: 1.82;
  }

  .prose :global(p) {
    margin: 0 0 1.3em;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin: 2em 0 0.7em;
    line-height: 1.25;
  }

  .prose :global(code) {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface-strong);
    padding: 0.1em 0.35em;
  }
</style>
